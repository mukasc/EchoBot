      "speaker_discord_id": "411916947773587456",
      "speaker_character_name": null,
      "text": "Não é só distância, não é só distância",
      "message_type": "ic",
      "timestamp_start": 312.46,
      "timestamp_end": 314.26,
      "timestamp_absolute_start": "2026-04-22T19:02:42.839000+00:00",
