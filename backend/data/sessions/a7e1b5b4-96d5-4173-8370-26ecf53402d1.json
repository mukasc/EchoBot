      "uncertain_terms": []
    },
    {
      "id": "65c43119-fcfd-40c4-acda-507201d1f15d",
      "speaker_discord_id": "411916947773587456",
      "speaker_character_name": null,
      "text": "Eu não sou pescoço, você conhece só um canto",
      "message_type": "ic",
      "timestamp_start": 311.16,
      "timestamp_end": 312.46,
      "timestamp_absolute_start": "2026-04-22T19:02:41.539000+00:00",
