    {
      "id": "f8522f0d-a867-4b83-b8fc-269b771d276d",
      "speaker_discord_id": "420362662208339968",
      "speaker_character_name": null,
      "text": "Agora a gente vai testar com o buscador Titãs.",
      "message_type": "ic",
      "timestamp_start": 0.0,
      "timestamp_end": 3.36,
      "timestamp_absolute_start": "2026-04-22T17:45:38.794000+00:00",
