      "speaker_discord_id": "411916947773587456",
      "speaker_character_name": null,
      "text": "O que se deu a vida de um indivíduo, já teve um tempo passado que se desabou",
      "message_type": "ic",
      "timestamp_start": 65.86,
      "timestamp_end": 68.86,
