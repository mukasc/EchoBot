      "speaker_discord_id": "411916947773587456",
      "speaker_character_name": null,
      "text": "O que se fez na zona da cidade, já ficou o seu timeiro, já era trabalhador",
      "message_type": "ic",
      "timestamp_start": 62.86,
      "timestamp_end": 65.86,
      "timestamp_absolute_start": "2026-04-22T17:46:41.654000+00:00",
